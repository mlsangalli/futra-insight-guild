# ⚠️ NUNCA commitar o arquivo .env no repositório!
# Copie este arquivo para .env e preencha com suas credenciais.
# Após o deploy, configure as variáveis no painel do seu provedor de hospedagem.
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here
VITE_SUPABASE_PROJECT_ID=your_project_id_here

# Firebase Cloud Messaging (push notifications) — opcional
# Se não preenchido, o app funciona normalmente, apenas sem push em background.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
